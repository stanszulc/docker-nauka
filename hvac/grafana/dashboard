          "rawQuery": true,
          "rawSql": "SELECT \n  s.device_id,\n  s.last_failure_type AS failure,\n  s.last_severity AS severity,\n  ROUND(m.fail_probability::numeric, 2) AS fail_prob,\n  m.is_pre_failure,\n  ROUND(s.uptime_seconds::numeric/60, 1) AS uptime_min,\n  ROUND(EXTRACT(EPOCH FROM (NOW() - s.last_seen))::numeric, 0) AS seconds_ago\nFROM hvac_device_status s\nLEFT JOIN LATERAL (\n  SELECT fail_probability, is_pre_failure\n  FROM hvac_metrics\n  WHERE device_id = s.device_id\n  ORDER BY ts DESC LIMIT 1\n) m ON true\nWHERE s.last_seen > NOW() - INTERVAL '10 minutes'\nORDER BY fail_prob DESC NULLS LAST",
