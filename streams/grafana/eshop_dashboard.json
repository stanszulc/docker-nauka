{
  "title": "E-SHOP Activity Monitor",
  "uid": "eshop-monitor",
  "tags": ["eshop", "ecommerce"],
  "timezone": "Europe/Warsaw",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "💰 Revenue (last 1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyPLN",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "green", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, SUM((data->>'amount')::float) AS value FROM purchase_events WHERE created_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "title": "🛒 Orders (last 1h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, COUNT(*) AS value FROM purchase_events WHERE created_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "👥 Active Users (last 5 min)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, COUNT(DISTINCT (data->>'user_id')) AS value FROM click_events WHERE created_at > NOW() - INTERVAL '5 minutes'",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "📊 Avg Order Value (last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyPLN",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 150 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, AVG((data->>'amount')::float) AS value FROM purchase_events WHERE created_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "🔄 Conversion Rate (clicks → purchases, last 1h)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 15 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, ROUND(100.0 * COUNT(DISTINCT p.id) / NULLIF(COUNT(DISTINCT c.id), 0), 2) AS value FROM click_events c LEFT JOIN purchase_events p ON p.created_at BETWEEN c.created_at - INTERVAL '30 minutes' AND c.created_at + INTERVAL '30 minutes' AND (p.data->>'user_id') = (c.data->>'user_id') WHERE c.created_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "title": "🚨 Click/Purchase Ratio (anomaly signal)",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 35 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, ROUND(1.0 * COUNT(*) / NULLIF((SELECT COUNT(*) FROM purchase_events WHERE created_at > NOW() - INTERVAL '1 hour'), 0), 1) AS value FROM click_events WHERE created_at > NOW() - INTERVAL '1 hour'",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "📈 Revenue per Minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyPLN",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT date_trunc('minute', created_at AT TIME ZONE 'UTC' AT TIME ZONE 'Europe/Warsaw') AS time, SUM((data->>'amount')::float) AS \"Revenue\" FROM purchase_events WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 8,
      "title": "👆 User Activity (clicks & logins per minute)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT date_trunc('minute', created_at AT TIME ZONE 'UTC' AT TIME ZONE 'Europe/Warsaw') AS time, COUNT(*) AS \"Clicks\" FROM click_events WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        },
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT date_trunc('minute', created_at AT TIME ZONE 'UTC' AT TIME ZONE 'Europe/Warsaw') AS time, COUNT(*) AS \"Logins\" FROM login_events WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 9,
      "title": "🗺️ Purchase Locations",
      "type": "geomap",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 9 },
      "options": {
        "view": { "id": "fit", "lat": 50.06, "lon": 19.94, "zoom": 11 },
        "layers": [
          {
            "type": "markers",
            "config": {
              "style": {
                "size": { "fixed": 5 },
                "color": { "fixed": "green" },
                "opacity": 0.7
              },
              "showLegend": true
            },
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "name": "Purchases"
          }
        ],
        "controls": { "showZoom": true, "mouseWheelZoom": true }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT created_at AS time, (data->'gps'->>'lat')::float AS lat, (data->'gps'->>'lon')::float AS lon, (data->>'amount')::float AS amount FROM purchase_events WHERE $__timeFilter(created_at) ORDER BY created_at DESC LIMIT 500",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "title": "📋 Conversion Funnel: Login → Click → Purchase",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 9 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-BlPu" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "eshop-pg" },
          "rawSql": "SELECT NOW() AS time, (SELECT COUNT(*) FROM login_events WHERE created_at > NOW() - INTERVAL '1 hour') AS \"Logins\", (SELECT COUNT(*) FROM click_events WHERE created_at > NOW() - INTERVAL '1 hour') AS \"Clicks\", (SELECT COUNT(*) FROM purchase_events WHERE created_at > NOW() - INTERVAL '1 hour') AS \"Purchases\"",
          "format": "table"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
